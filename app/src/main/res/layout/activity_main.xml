<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/title_activity_main"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp" />

    <TextView
        android:id="@+id/tv_keyboard_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/status_not_default"
        android:textSize="16sp"
        android:layout_marginBottom="16dp"
        android:padding="8dp"
        android:background="@android:color/darker_gray" />

    <Button
        android:id="@+id/btn_set_default"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_set_as_default"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btn_upload_manager"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_upload_manager"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btn_settings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_settings" />

</LinearLayout>
